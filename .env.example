NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here
MONGO_URI=mongodb://localhost:27017/nextjs-starter

# Google OAuth — https://console.developers.google.com
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-key
# Comma-separated fallback chain — tried in order until one returns a usable plan
OPENROUTER_MODELS=nvidia/nemotron-3.5-content-safety:free,liquid/lfm-2.5-1.2b-instruct:free,nvidia/nemotron-3-nano-30b-a3b:free
OPENROUTER_MAX_TOKENS=8000
